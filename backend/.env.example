# ===========================================
# DATABASE CONFIGURATION (Neon PostgreSQL)
# ===========================================

# Neon connection string with connection pooling (used by the app at runtime)
# Get this from your Neon project dashboard -> Connection Details -> Pooled connection
DATABASE_URL="postgresql://[user]:[password]@[endpoint]-pooler.neon.tech/[dbname]?sslmode=require"

# Direct (non-pooled) connection URL — required by Prisma migrations
# Get this from Neon dashboard -> Connection Details -> Direct connection
DIRECT_URL="postgresql://[user]:[password]@[endpoint].neon.tech/[dbname]?sslmode=require"

# ===========================================
# JWT AUTHENTICATION
# ===========================================
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# ===========================================
# EMAIL SERVICE (Resend)
# ===========================================
RESEND_API_KEY="your-resend-api-key"
RESEND_FROM_EMAIL="noreply@relon.com"

# ===========================================
# FRONTEND CONFIGURATION
# ===========================================
# Frontend URL (for password reset links, email templates)
FRONTEND_URL="http://localhost:3000"

# CORS Origin (comma-separated for multiple origins)
CORS_ORIGIN="http://localhost:3000"
# Production example:
# CORS_ORIGIN="https://yourdomain.com,https://www.yourdomain.com"

# ===========================================
# AI PROVIDER CONFIGURATION
# ===========================================
OPENAI_API_KEY="your-openai-api-key"
AI_DEFAULT_PROVIDER="OPENAI"

# Optional: Add other AI providers
# ANTHROPIC_API_KEY="your-anthropic-api-key"
# GEMINI_API_KEY="your-gemini-api-key"

# ===========================================
# GOOGLE CLOUD PLATFORM (GCP) STORAGE
# ===========================================
GCP_PROJECT_ID="your-gcp-project-id"
GCP_STORAGE_BUCKET="your-bucket-name"

# Local Development: Path to service account key file
GCP_SERVICE_ACCOUNT_KEY_PATH="./gcp-service-account-key.json"

# Production (Cloud Run): Use Workload Identity (no key file needed)
# Leave GCP_SERVICE_ACCOUNT_KEY_PATH empty or unset when using Workload Identity

# ===========================================
# QUICKBOOKS ONLINE INTEGRATION
# ===========================================
# Create an app at https://developer.intuit.com/ to get these credentials
QB_CLIENT_ID="your-intuit-client-id"
QB_CLIENT_SECRET="your-intuit-client-secret"
# Must exactly match the redirect URI registered in the Intuit developer portal
QB_REDIRECT_URI="http://localhost:4000/quickbooks/callback"
# "sandbox" for testing, "production" for live QB company
QB_ENVIRONMENT="sandbox"
# Intuit webhook verifier token (from Intuit developer portal → Webhooks)
QB_WEBHOOK_VERIFIER_TOKEN="your-webhook-verifier-token"
# QB Account ID to use as IncomeAccountRef when creating Items.
# Find it in QB: Accounting → Chart of Accounts → your income account → hover for ID.
# If not set, the app will query QB for the first Income account each time (slower).
QB_INCOME_ACCOUNT_ID=""

# ===========================================
# SERVER CONFIGURATION
# ===========================================
PORT=4000
NODE_ENV="development"
# Production: NODE_ENV="production"

# ===========================================
# LIBREOFFICE (proposal → PDF conversion)
# ===========================================
# macOS (Homebrew): /opt/homebrew/bin/soffice
# Linux/Docker:     soffice (on PATH via apt libreoffice-writer install)
# Set this if the backend can't find soffice automatically on your machine.
# LIBREOFFICE_BINARY=/opt/homebrew/bin/soffice

